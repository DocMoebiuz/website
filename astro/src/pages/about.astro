---
import Default from "../layouts/default.astro"
import Hero from "@/components/mobiflight/hero.astro"
import Container from "@/components/mobiflight/container.astro"
import Button from "@/components/starwind/button/Button.astro"
import Badge from "@/components/starwind/badge/Badge.astro"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card"

const heroImage = "https://shop.mobiflight.com/wp-content/uploads/2026/02/homepage-mcp.jpg"

const simulators = ["MSFS 2024", "MSFS 2020", "X-Plane 12", "X-Plane 11", "P3D", "FSX"]

const usp = [
  {
    title: "Plug-and-play and DIY friendly",
    teaser: "Start with off-the-shelf hardware or build your own cockpit panels with Arduino and Raspberry Pi.",
  },
  {
    title: "Works with major simulators",
    teaser: "Control your setup in Microsoft Flight Simulator, X-Plane, and other leading simulation platforms.",
  },
  {
    title: "Open source and community-driven",
    teaser: "Use MobiFlight for free, improve it together, and learn from one of the most active sim communities.",
  },
  {
    title: "From first switch to full cockpit",
    teaser: "Scale from a small home setup to complex multi-module cockpits with one consistent toolchain.",
  },
]

const team = [
  { role: "Founder", description: "Vision, product direction, and community stewardship." },
  { role: "Core Development", description: "Desktop app, firmware, and simulator integration." },
  { role: "Community & Support", description: "Discord moderation, events, and user guidance." },
  { role: "Content & Ecosystem", description: "HubHop presets, releases, and external partnerships." },
]
---

<Default title="About MobiFlight">
  <Hero
    headline="MobiFlight Project Information"
    tagline="MobiFlight connects cockpit hardware to your flight simulator and gives both sim enthusiasts and DIY builders a powerful platform to fly with real controls."
    ctas={[{ text:"Download MobiFlight", link: "/download", variant: "primary" }]}
    imageSrc={heroImage}
  />

  <Container>
    <section class="py-8">
      <h2 class="text-3xl font-bold mb-4">What It Does and Why Use It</h2>
      <p class="text-lg mb-4">
        MobiFlight is the bridge between your simulator and physical cockpit controls. It helps you turn hardware inputs
        and outputs into a practical, immersive flying experience without vendor lock-in.
      </p>
      <div class="flex flex-wrap gap-2 mb-4">
        <Badge>Built for Off-the-Shelf Hardware Users</Badge>
        <Badge>Built for DIY Cockpit Builders</Badge>
      </div>
      <p class="text-muted-foreground">
        Whether you buy ready-made panels or build your own from scratch, MobiFlight supports both paths.
      </p>
    </section>
  </Container>

  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-4">Features and USPs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        {usp.map((item) => (
          <Card>
            <CardHeader>
              <CardTitle>{item.title}</CardTitle>
            </CardHeader>
            <CardContent>
              <CardDescription>{item.teaser}</CardDescription>
            </CardContent>
          </Card>
        ))}
      </div>
      <h3 class="text-xl font-semibold mb-3">Supported Simulators</h3>
      <div class="flex flex-wrap gap-2">
        {simulators.map((sim) => (
          <Badge>{sim}</Badge>
        ))}
      </div>
    </section>
  </Container>

  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-4">The Ecosystem</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <article class="border rounded-lg p-4">
          <h3 class="text-xl font-semibold mb-2">MobiFlight Connector</h3>
          <p>The desktop application is the core bridge between hardware devices and simulator events.</p>
        </article>
        <article class="border rounded-lg p-4">
          <h3 class="text-xl font-semibold mb-2">Off-the-Shelf Controller Support</h3>
          <p>Use compatible, ready-to-buy hardware and get productive quickly with proven device support.</p>
        </article>
        <article class="border rounded-lg p-4">
          <h3 class="text-xl font-semibold mb-2">DIY Firmware Stack</h3>
          <p>Flash firmware for Arduino and Raspberry Pi Pico boards and build fully custom cockpit devices.</p>
        </article>
      </div>
    </section>
  </Container>

  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-4">Community and HubHop</h2>
      <p class="mb-4">
        MobiFlight thrives because people share profiles, wiring ideas, and lessons learned. The community is built around
        helping each other improve.
      </p>
      <p class="mb-6">
        HubHop is the preset database that helps you discover and share mappings when creating your own profiles.
      </p>
      <div class="flex flex-wrap gap-3">
        <Button href="https://mobiflight.com/discord" target="_blank" rel="noopener noreferrer">Join Discord</Button>
        <Button href="https://hubhop.mobiflight.com" target="_blank" rel="noopener noreferrer" variant="secondary">
          Open HubHop
        </Button>
      </div>
    </section>
  </Container>

  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-4">Open Source on GitHub</h2>
      <p class="mb-4">
        GitHub is where we build in the open, track issues, share releases, and collaborate with contributors.
      </p>
      <Button href="https://github.com/MobiFlight" target="_blank" rel="noopener noreferrer" variant="outline">
        Visit MobiFlight on GitHub
      </Button>
    </section>
  </Container>

  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-4">About the Founder</h2>
      <div class="border rounded-lg p-5">
        <p class="text-muted-foreground">
          Placeholder: Add founder story, background, mission, and vision for the project.
        </p>
      </div>
    </section>
  </Container>

  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-4">About the Team</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {team.map((member) => (
          <article class="border rounded-lg p-4">
            <h3 class="text-xl font-semibold mb-2">{member.role}</h3>
            <p class="text-muted-foreground">{member.description}</p>
          </article>
        ))}
      </div>
      <p class="mt-5 text-sm text-muted-foreground">
        This site intentionally stays static. Member login and account functionality will be handled separately via
        club.mobiflight.com.
      </p>
    </section>
  </Container>
</Default>