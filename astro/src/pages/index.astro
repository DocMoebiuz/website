---
import Default from "../layouts/default.astro"
import Hero from "@/components/mobiflight/hero.astro"
import Container from "@/components/mobiflight/container.astro"
import News from "@/components/mobiflight/news.astro"
import Sponsors from "@/components/mobiflight/sponsors.astro"
import ValueProposition from "@/components/mobiflight/value-proposition.astro"

const heroImage = "https://shop.mobiflight.com/wp-content/uploads/2026/02/homepage-mcp.jpg"
---

<Default title="MobiFlight — Soar Higher with the Ultimate Flight Sim Hardware Companion">
  <Hero
    headline="Manage your flight sim hardware"
    tagline="Easy. Free. 100% Open Source."
    ctas={[
      { text: "Download Free", link: "/download", variant: "primary" },
      { text: "View Docs", link: "https://docs.mobiflight.com", variant: "outline" }
    ]}
    imageSrc={heroImage}
  />
  <ValueProposition />
  <Sponsors />
  <News />
  

  <!-- Quick Navigation Hub -->
  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-6">Everything MobiFlight</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <a href="https://docs.mobiflight.com" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">📖 Documentation</a>
        <a href="https://shop.mobiflight.com" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">🛒 Shop</a>
        <a href="https://mobiflight.com/discord" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">💬 Community (Discord)</a>
        <a href="https://hubhop.mobiflight.com" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">✈️ HubHop Presets</a>
        <a href="/club" class="p-4 border rounded-lg hover:bg-muted transition-colors">⭐ MobiFlight Club</a>
        <a href="/services" class="p-4 border rounded-lg hover:bg-muted transition-colors">🤝 Professional Services</a>
      </div>
    </section>
  </Container>
</Default>