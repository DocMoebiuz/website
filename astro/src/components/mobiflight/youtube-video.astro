---
type Props = {
  src: string
  title: string
  class?: string
  height?: number
  width?: number
}
const { src, title, class: className, height=315, width=560 } = Astro.props
---

<iframe
  class={className}
  width={width}
  height={height}
  src={src}
  title={title}
  frameborder="0"
  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
  referrerpolicy="strict-origin-when-cross-origin"
  allowfullscreen>
</iframe>
